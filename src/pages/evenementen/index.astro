---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';
import { upcomingEvents, pastEvents, syncMeta } from '../../content/events-loader';
---

<BaseLayout title="Evenementen" description="Alle evenementen en activiteiten in de Kruidenwijk Nijverdal.">
  <div class="page-hero">
    <div class="container" style="position:relative; z-index:1;">
      <h1>Evenementen</h1>
      <p>Ontdek wat er te doen is in de Kruidenwijk. Van buurtfeesten tot workshops.</p>
      {syncMeta.total > 0 && (
        <p class="sync-badge">
          🔄 Evenementen automatisch gesynchroniseerd met
          <a href="https://dekruidenwijk.nl/activiteiten/" target="_blank" rel="noopener">dekruidenwijk.nl</a>
        </p>
      )}
    </div>
  </div>

  {upcomingEvents.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <span class="section-header__label">Binnenkort</span>
          <h2 class="section-header__title">Komende evenementen</h2>
        </div>
        <div class="events-list">
          {upcomingEvents.map(event => (
            <EventCard
              title={event.title}
              slug={event.slug}
              date={event.date}
              time={event.time}
              location={event.location}
              description={event.description}
              isExternal={event.isExternal}
              url={event.url}
              source={event.source}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {pastEvents.length > 0 && (
    <section class="section section--linen">
      <div class="container">
        <div class="section-header">
          <span class="section-header__label">Archief</span>
          <h2 class="section-header__title">Afgelopen evenementen</h2>
        </div>
        <div class="events-list">
          {pastEvents.map(event => (
            <EventCard
              title={event.title}
              slug={event.slug}
              date={event.date}
              time={event.time}
              location={event.location}
              description={event.description}
              isExternal={event.isExternal}
              url={event.url}
              source={event.source}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .events-list { display:flex; flex-direction:column; gap:1.25rem; max-width:800px; margin:0 auto; }
  .sync-badge {
    display:inline-flex;
    align-items:center;
    gap:.4rem;
    margin-top:.75rem;
    padding:.4rem 1rem;
    background:rgba(255,255,255,.15);
    border-radius:50px;
    font-size:.8rem;
    color:rgba(255,255,255,.8);
  }
  .sync-badge a { color:#fff; text-decoration:underline; text-underline-offset:2px; }
</style>
