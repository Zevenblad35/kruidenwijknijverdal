---
interface Props {
  title: string;
  slug: string;
  date: string;
  time: string;
  location: string;
  description: string;
  category?: string;
}

const { title, slug, date, time, location, description, category = 'Evenement' } = Astro.props;

const d = new Date(date);
const day = d.getDate();
const month = d.toLocaleDateString('nl-NL', { month: 'short' }).toUpperCase();
const fullDate = d.toLocaleDateString('nl-NL', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
---

<article class="event-card animate-in">
  <div class="date-badge">
    <span class="date-badge__day">{day}</span>
    <span class="date-badge__month">{month}</span>
  </div>
  <div class="event-card__body">
    <h3 class="event-card__title">
      <a href={`/evenementen/${slug}/`}>{title}</a>
    </h3>
    <div class="event-card__details">
      <span class="event-card__detail">📅 {fullDate}</span>
      <span class="event-card__detail">🕐 {time}</span>
      <span class="event-card__detail">📍 {location}</span>
    </div>
    <p class="event-card__desc">{description}</p>
  </div>
</article>

<style>
  .event-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    background: #fff;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    transition: all 0.4s var(--ease-out);
  }

  .event-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-hover);
  }

  .event-card__body {
    flex: 1;
    min-width: 0;
  }

  .event-card__title {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .event-card__title a {
    color: var(--bark);
    text-decoration: none;
  }

  .event-card__title a:hover {
    color: var(--sage);
  }

  .event-card__details {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    margin-bottom: 0.75rem;
  }

  .event-card__detail {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .event-card__desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
